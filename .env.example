# Copy to .env.local and fill in. Vercel project settings need the same vars.

# Resend API key, from https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxx

# Where every application gets emailed
FOUNDER_EMAIL=khaldounbaniali@gmail.com

# The "from" address used by Resend. Until your domain is verified at
# Resend, leave this as the Resend sandbox address; Resend lets you send
# from onboarding@resend.dev with no domain verification needed.
FROM_EMAIL=onboarding@resend.dev
